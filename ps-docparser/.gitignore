# ps-docparser .gitignore

# API 키, 환경변수
.env

# 캐시 데이터 (코드와 분리된 숨김 폴더)
.env
.cache/

# Python
__pycache__/
*.py[cod]
*.pyo

# 파일 시스템 및 테스트
venv_test/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# 출력 파일 (루트 output/ 만 제외, tests/golden/output/ 제외 안 함)
/output/

# Phase15 frontend
frontend/node_modules/
frontend/node_modules.partial-delete*/
frontend/dist/

# 골든 테스트 산출물 (테스트 러닝마다 자동 생성)
tests/golden/test_output/

# 통합 테스트 산출물 (test_file_collision.py 등 생성)
conflict_dir/
readonly_dir/
dummy_batch/
log_tail.json
stats.json

# 로그 및 테스트 부산물
*.log
cov.txt
crop_result_debug.txt
results_slice.txt
test_results.log
pytest_*.txt
pytest_*.log
dummy_output.xlsx
test*.pdf
scratch_test.py

# IDE
.vscode/
.idea/
